Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # 1. Menghilangkan index.php dari URL
    # Redirect /index.php ke /
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s(.*)/index\.php [NC]
    RewriteRule ^ %1/ [R=301,L]

    # 2. Menghilangkan ekstensi .php dari URL (Redirect eksternal)
    # Jangan redirect jika request method adalah POST (untuk menjaga data form)
    RewriteCond %{REQUEST_METHOD} !POST
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
    RewriteRule ^ %1 [R=301,L]

    # 3. Rewrite internal untuk mengakses file .php tanpa ekstensi
    # Jika request bukan direktori
    RewriteCond %{REQUEST_FILENAME} !-d
    # Dan file .php nya ada
    RewriteCond %{REQUEST_FILENAME}.php -f
    # Maka rewrite ke file .php
    RewriteRule ^(.+)$ $1.php [L]
</IfModule>
